{
  "name": "turbolabit/php-symfony-shopify-sdk",
  "description": "",
  "type": "symfony-bundle",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "TurboLabIt\\ShopifySdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TurboLabIt\\ShopifySdk\\tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Zane"
    }
  ],
  "require": {
    "php": "^8.2",
    "saloonphp/saloon": "^2.12",
    "symfony/twig-pack": "@stable",
    "symfony/http-client": "@stable",
    "symfony/mime": "@stable"
  },
  "require-dev": {
    "symfony/yaml": "@stable",
    "symfony/dotenv": "@stable",
    "symfony/config": "@stable",
    "symfony/dependency-injection": "@stable",
    "symfony/http-kernel": "@stable",
    "symfony/test-pack": "@stable"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": false,
      "symfony/flex": true
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    }
  }
}
