{# https://shopify.dev/docs/api/admin-graphql/latest/mutations/metaobjectDefinitionUpdate #}
{# Reconciles an existing metaobject definition: `creates` = field defs to add, `updates` = existing fields whose #}
{# label (name) drifted and must be renamed. key/type are immutable, so `update` ops carry only key + name. #}
{# Strings go through |json_encode|raw so special chars (&, ", …) are escaped for GraphQL, never HTML-entitied. #}
mutation {
  metaobjectDefinitionUpdate(id: {{ id|json_encode|raw }}, definition: {
    fieldDefinitions: [
      {%- for f in creates %}
      {% if not loop.first %},{% endif %}{ create: { key: {{ f.key|json_encode|raw }}, name: {{ f.name|json_encode|raw }}, type: {{ f.type|json_encode|raw }} } }
      {%- endfor %}
      {%- for f in updates %}
      {% if creates|length > 0 or not loop.first %},{% endif %}{ update: { key: {{ f.key|json_encode|raw }}, name: {{ f.name|json_encode|raw }} } }
      {%- endfor %}
    ]
  }) {
    metaobjectDefinition { id type }
    userErrors { field message code }
  }
}
