{# https://shopify.dev/docs/api/admin-graphql/latest/mutations/collectionCreate #}
mutation {
  collectionCreate(input: {
    title:  {{ title|json_encode|raw }},
    handle: {{ handle|json_encode|raw }}
    {%- if ruleSet is defined and ruleSet -%}
    ,
    ruleSet: {
      appliedDisjunctively: {{ ruleSet.appliedDisjunctively|default(false) ? 'true' : 'false' }},
      rules: [
        {%- for r in ruleSet.rules %}
        { column: {{ r.column }}, relation: {{ r.relation }}, condition: {{ r.condition|json_encode|raw }} }{% if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    {%- endif -%}
    {%- if metafields is defined and metafields|length > 0 -%}
    ,
    metafields: [
      {%- for m in metafields %}
      { namespace: {{ m.namespace|json_encode|raw }}, key: {{ m.key|json_encode|raw }}, type: {{ m.type|json_encode|raw }}, value: {{ m.value|json_encode|raw }} }{% if not loop.last %},{% endif %}
      {%- endfor %}
    ]
    {%- endif %}
  }) {
    collection {
      id
      title
      handle
      ruleSet {
        appliedDisjunctively
        rules { column relation condition }
      }
    }
    userErrors {
      field
      message
    }
  }
}
