{# https://shopify.dev/docs/api/admin-graphql/latest/mutations/publishablePublish #}
mutation {
  publishablePublish(
    id: "{{ resourceGid }}",
    input: [
      {%- for pubId in publicationIds %}
      { publicationId: "{{ pubId }}" }{% if not loop.last %},{% endif %}
      {%- endfor %}
    ]
  ) {
    publishable {
      availablePublicationsCount { count }
      resourcePublicationsCount { count }
    }
    userErrors {
      field
      message
    }
  }
}
