{# https://shopify.dev/docs/api/admin-graphql/latest/mutations/metafieldDefinitionUpdate #}
mutation {
  metafieldDefinitionUpdate(definition: {
    namespace:  "{{ namespace }}",
    key:        "{{ key }}",
    ownerType:  {{ ownerType }},
    name:       "{{ name }}"
    {#- pin is emitted ONLY when the caller passes it: metafieldDefinitionUpdate leaves the pin/unpin state
        UNCHANGED when the field is absent, so an omitted `pin` preserves whatever the operator set (an explicit
        `pin: false` here would UNPIN on every reconcile). See ImportProducts buildMetafieldDefinitions(). -#}
    {%- if pin is defined %},
    pin:        {{ pin ? 'true' : 'false' }}
    {%- endif %}
    {%- if validations is defined and validations|length > 0 %},
    validations: [
      {%- for v in validations %}
      { name: "{{ v.name }}", value: "{{ v.value }}" }{% if not loop.last %},{% endif %}
      {%- endfor %}
    ]
    {%- endif %}
    {%- if capabilities is defined and capabilities|length > 0 %},
    capabilities: {
      {%- for capability in capabilities %}
      {{ capability }}: { enabled: true }{% if not loop.last %},{% endif %}
      {%- endfor %}
    }
    {%- endif %}
  }) {
    updatedDefinition {
      id
      namespace
      key
      name
      pinnedPosition
    }
    userErrors {
      field
      message
      code
    }
  }
}
